#!/usr/bin/env bash
set -euo pipefail

script_source="${BASH_SOURCE[0]}"
while [[ -L "${script_source}" ]]; do
  script_dir="$(cd "$(dirname "${script_source}")" && pwd -P)"
  script_source="$(readlink "${script_source}")"
  [[ "${script_source}" != /* ]] && script_source="${script_dir}/${script_source}"
done

script_dir="$(cd "$(dirname "${script_source}")" && pwd -P)"

default_robot_runs_host="${OMNISEER_ROBOT_HOST:-192.168.1.178}"
default_robot_runs_user="${OMNISEER_ROBOT_USER:-radxa}"
default_robot_runs_root="${OMNISEER_ROBOT_RUNS_ROOT:-/home/radxa/apps/omniseer/runs}"

# shellcheck disable=SC1091
source "${script_dir}/lib/log.sh"
# shellcheck disable=SC1091
source "${script_dir}/lib/common.sh"
# shellcheck disable=SC1091
source "${script_dir}/lib/ros.sh"

usage() {
  cat <<'EOF'
Usage:
  scripts/omni <command> [args...]

Commands:
  setup   Environment and dependency helpers.
  build   Local build helpers. Defaults to all available artifacts.
  test    Targeted local verification helpers. Defaults to ROS.
  run     Operator-facing run commands for sim, real, monitor, and teleop.
  runtime Build, verify, push, and pull robot runtime container checkpoints.
  runs    Inspect, list, and retrieve perception run bundles.
  check   Passive verification helpers.
  doctor  Report local build, runtime, and robot dependency state.
  flash   Hardware flashing helpers.
  docs    Documentation build helpers.
  env     Show resolved Omniseer environment settings.
  clean   Remove local build artifacts.
  help    Show this help text.

Examples:
  scripts/omni setup ros-deps
  scripts/omni doctor
  scripts/omni build
  scripts/omni run sim headless:=true
  scripts/omni run real
  scripts/omni runs list
  scripts/omni runs pull demo_001
  scripts/omni runs inspect runs/imported/demo_001
  scripts/omni runs annotate runs/imported/demo_001
  scripts/omni runs report runs/imported/demo_001
  scripts/omni runs local-list --root runs
  scripts/omni test smoke-sim
  scripts/omni build ros
  scripts/omni build runtime-container
  scripts/omni runtime build
  scripts/omni runtime verify --stage full
  scripts/omni runtime push
  scripts/omni check real-perception
  scripts/omni flash teensy
  scripts/omni docs build
  scripts/omni clean ros
EOF
}

run_usage() {
  cat <<'EOF'
Usage:
  scripts/omni run sim [launch args...]
  scripts/omni run real [--profile <name>] [recording flags] [--mode <mode>] [mode] [launch args...]
  scripts/omni run monitor [monitor args...]
  scripts/omni run teleop

Real profiles:
  current        Default alias for the current supported real robot runtime.
  operator       Gateway, native vision, preview, bounded teleop, and recording.
  perception     Native vision and recording without the gateway operator surface.
  legacy-teleop  Older keyboard teleop path kept for hardware diagnostics.

Real modes:
  bringup   Start the selected real profile in the foreground.
  smoke     Start the selected profile, run its verifier, then stop.
  verify    Run the selected profile verifier against an existing ROS graph.
  teleop    Start only the stamped keyboard teleop publisher.
  operator  Legacy-teleop profile only: start bringup, then open keyboard teleop.

Recording flags:
  --record
  --record-run <run_id>
  --record-out <path>
  --record-duration-sec <seconds>
  --record-notes <text>
  --record-classes <text>
  --record-overwrite
EOF
}

runs_usage() {
  cat <<'EOF'
Usage:
  scripts/omni runs inspect <run_dir> [--json]
  scripts/omni runs annotate <run_dir> [--overwrite]
  scripts/omni runs report <run_dir> [--overwrite]
  scripts/omni runs local-list [--root <local-runs-root>]
  scripts/omni runs list [retrieval args...]
  scripts/omni runs pull <run_id> [retrieval args...]

Retrieval args:
  --host <robot-ip>
  --user <ssh-user>
  --remote-root <robot-runs-root>
  --import-root <local-import-root>
  --out <local-run-dir>
  --overwrite

Defaults:
  --host 192.168.1.178, override with OMNISEER_ROBOT_HOST
  --user radxa, override with OMNISEER_ROBOT_USER
  --remote-root /home/radxa/apps/omniseer/runs, override with OMNISEER_ROBOT_RUNS_ROOT
EOF
}

omni_arg_present() {
  local name="$1"
  shift
  local arg
  for arg in "$@"; do
    if [[ "${arg}" == "${name}" || "${arg}" == "${name}="* ]]; then
      return 0
    fi
  done
  return 1
}

env_usage() {
  cat <<'EOF'
Usage:
  scripts/omni env

Shows resolved repo, ROS, workspace, and real profile defaults.
EOF
}

show_env() {
  cat <<EOF
repo_root=$(omni_repo_root)
scripts_root=$(omni_scripts_root)
ros_setup=$(omni_default_ros_setup)
ws_setup=$(omni_default_ws_setup)
uros_ws_setup=$(omni_default_uros_ws_setup)
ros_ws_root=$(omni_ros_ws_root)
default_real_profile=$(omni_default_real_profile)
current_real_profile=$(omni_current_real_profile)
supported_real_profiles=$(omni_supported_real_profiles | paste -sd, -)
EOF
}

command_group="${1:-help}"
if [[ $# -gt 0 ]]; then
  shift
fi

case "${command_group}" in
  help|-h|--help)
    usage
    ;;
  setup)
    subcommand="${1:-help}"
    if [[ $# -gt 0 ]]; then
      shift
    fi
    case "${subcommand}" in
      ros-deps)
        exec "${script_dir}/setup/dev.sh" ros-deps "$@"
        ;;
      help|-h|--help)
        exec "${script_dir}/setup/dev.sh" --help
        ;;
      *)
        omni_die "unknown setup subcommand: ${subcommand}"
        ;;
    esac
    ;;
  build)
    subcommand="${1:-all}"
    if [[ $# -gt 0 ]]; then
      shift
    fi
    case "${subcommand}" in
      all)
        exec "${script_dir}/build/all.sh" "$@"
        ;;
      strict)
        exec "${script_dir}/build/all.sh" --strict "$@"
        ;;
      ros)
        exec "${script_dir}/build/ros.sh" "$@"
        ;;
      vision)
        exec "${script_dir}/build/vision.sh" "$@"
        ;;
      firmware)
        exec "${script_dir}/build/firmware.sh" "$@"
        ;;
      runtime-container|container|runtime)
        exec "${script_dir}/build/runtime_container.sh" "$@"
        ;;
      help|-h|--help)
        cat <<'EOF'
Usage:
  scripts/omni build [all]
  scripts/omni build strict
  scripts/omni build ros --with-vision
  scripts/omni build ros --without-vision
  scripts/omni build vision
  scripts/omni build firmware
  scripts/omni build runtime-container
EOF
        ;;
      *)
        omni_die "unknown build subcommand: ${subcommand}"
        ;;
    esac
    ;;
  up)
    omni_warn "'scripts/omni up' is deprecated; run 'scripts/omni build ros' then 'scripts/omni run sim' or 'scripts/omni run real'"
    exec "${script_dir}/up.sh" "$@"
    ;;
  test)
    subcommand="${1:-ros}"
    if [[ $# -gt 0 ]]; then
      shift
    fi
    case "${subcommand}" in
      ros)
        exec "${script_dir}/test/ros.sh" "$@"
        ;;
      vision)
        exec "${script_dir}/test/vision.sh" "$@"
        ;;
      smoke-sim)
        exec "${script_dir}/test/smoke_sim.sh" "$@"
        ;;
      help|-h|--help)
        cat <<'EOF'
Usage:
  scripts/omni test [ros]
  scripts/omni test vision
  scripts/omni test smoke-sim
EOF
        ;;
      *)
        omni_die "unknown test subcommand: ${subcommand}"
        ;;
    esac
    ;;
  run)
    subcommand="${1:-help}"
    if [[ $# -gt 0 ]]; then
      shift
    fi
    case "${subcommand}" in
      sim)
        exec "${script_dir}/run/sim.sh" "$@"
        ;;
      real)
        exec "${script_dir}/run/real.sh" "$@"
        ;;
      monitor)
        exec "${script_dir}/run/monitor.sh" "$@"
        ;;
      teleop)
        exec "${script_dir}/run/teleop.sh" "$@"
        ;;
      help|-h|--help)
        run_usage
        ;;
      *)
        omni_die "unknown run subcommand: ${subcommand}"
        ;;
    esac
    ;;
  runtime)
    exec "${script_dir}/runtime.sh" "$@"
    ;;
  runs)
    subcommand="${1:-help}"
    if [[ $# -gt 0 ]]; then
      shift
    fi
    case "${subcommand}" in
      inspect)
        omni_source_ros_workspace
        exec ros2 run omniseer_experiments inspect_run "$@"
        ;;
      annotate)
        omni_source_ros_workspace
        exec ros2 run omniseer_experiments annotate_evidence "$@"
        ;;
      report)
        omni_source_ros_workspace
        exec ros2 run omniseer_experiments report_run "$@"
        ;;
      local-list)
        omni_source_ros_workspace
        exec ros2 run omniseer_experiments list_runs "$@"
        ;;
      list|pull)
        omni_source_ros_workspace
        run_args=("$@")
        if ! omni_arg_present "--host" "${run_args[@]}"; then
          run_args+=("--host" "${default_robot_runs_host}")
        fi
        if ! omni_arg_present "--user" "${run_args[@]}"; then
          run_args+=("--user" "${default_robot_runs_user}")
        fi
        if ! omni_arg_present "--remote-root" "${run_args[@]}"; then
          run_args+=("--remote-root" "${default_robot_runs_root}")
        fi
        exec ros2 run omniseer_experiments retrieve_runs "${subcommand}" "${run_args[@]}"
        ;;
      help|-h|--help)
        runs_usage
        ;;
      *)
        omni_die "unknown runs subcommand: ${subcommand}"
        ;;
    esac
    ;;
  check)
    subcommand="${1:-real-perception}"
    if [[ $# -gt 0 ]]; then
      shift
    fi
    case "${subcommand}" in
      real-perception)
        exec "${script_dir}/check/real_teleop_perception.sh" "$@"
        ;;
      help|-h|--help)
        cat <<'EOF'
Usage:
  scripts/omni check real-perception
EOF
        ;;
      *)
        omni_die "unknown check subcommand: ${subcommand}"
        ;;
    esac
    ;;
  doctor)
    exec "${script_dir}/doctor.sh" "$@"
    ;;
  flash)
    subcommand="${1:-help}"
    if [[ $# -gt 0 ]]; then
      shift
    fi
    case "${subcommand}" in
      teensy)
        exec "${script_dir}/flash/teensy.sh" "$@"
        ;;
      help|-h|--help)
        cat <<'EOF'
Usage:
  scripts/omni flash teensy
EOF
        ;;
      *)
        omni_die "unknown flash subcommand: ${subcommand}"
        ;;
    esac
    ;;
  docs)
    subcommand="${1:-help}"
    if [[ $# -gt 0 ]]; then
      shift
    fi
    case "${subcommand}" in
      build)
        exec "${script_dir}/docs/build.sh" "$@"
        ;;
      help|-h|--help)
        cat <<'EOF'
Usage:
  scripts/omni docs build
EOF
        ;;
      *)
        omni_die "unknown docs subcommand: ${subcommand}"
        ;;
    esac
    ;;
  env)
    if [[ "${1:-}" =~ ^(-h|--help|help)$ ]]; then
      env_usage
    else
      show_env
    fi
    ;;
  clean)
    subcommand="${1:-ros}"
    if [[ $# -gt 0 ]]; then
      shift
    fi
    case "${subcommand}" in
      ros|vision|docs|all)
        exec "${script_dir}/clean/local.sh" "${subcommand}" "$@"
        ;;
      help|-h|--help)
        exec "${script_dir}/clean/local.sh" --help
        ;;
      *)
        omni_die "unknown clean subcommand: ${subcommand}"
        ;;
    esac
    ;;
  *)
    omni_die "unknown top-level command: ${command_group}"
    ;;
esac
